set dotenv-load := true

# Run tests with coverage
test:
    gotestsum --format pkgname -- -race -coverprofile=coverage.out -covermode=atomic ./...
    go tool cover -func=coverage.out | tail -1

# Lint
style:
    golangci-lint run ./...

# Format
fmt:
    gofmt -w .
    goimports -w .

# Tidy dependencies
tidy:
    go mod tidy

# Build and push image to GHCR (just publish org=your-org version=v1.0.0)
publish org version:
    docker build -t ghcr.io/{{org}}/backend:{{version}} -t ghcr.io/{{org}}/backend:latest .
    docker push ghcr.io/{{org}}/backend:{{version}}
    docker push ghcr.io/{{org}}/backend:latest
